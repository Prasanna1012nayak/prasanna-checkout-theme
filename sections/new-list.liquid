 {% assign metaobject_list = page.metafields.custom.dummy_test.value %}
 

 {% paginate metaobject_list by 250 %}
     
    <div id="metaobject_list">
        {% for entry in metaobject_list %}
            <div>{{ entry.heading }}</div>
        {% endfor %}

    </div>

    {% if paginate.next %}
      <button id="load-more" data-next="{{paginate.next.url}}" >
        Read more
      </button>
    {% endif %}

{% endpaginate %}

  

 {% schema %}
  {
  "name": "new-list",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
    ],
     "presets": [
        {
        "name": "new-list"
        }
        ]
        }
 {% endschema %}

 <script>
    document.addEventListener("DOMContentLoaded", async function(){

    const container = document.getElementById("metaobject_list");
    const button = document.getElementById("load-more");

    if (!button) return;
    
      button.style.display = "none";  

    let nextUrl = button.dataset.next;

    while (nextUrl) {

        const response = await fetch(nextUrl);
        const html = await response.text();

        const doc = new DOMParser().parseFromString(html, "text/html");

        const newContainer = doc.querySelector("#metaobject_list");

        if (newContainer){
            container.insertAdjacentHTML("beforeend", newContainer.innerHTML);
        }
             
        const nextButton = doc.querySelector("#load-more");
        nextUrl = nextButton ? nextButton.dataset.next : null;
        }
        
        button.remove();
    });
</script>
    