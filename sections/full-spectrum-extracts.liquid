{{ 'section-full-spectrum-extracts.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="full-spectrum section-{{ section.id }}-padding" data-fs-section>
  <div class="full-spectrum__container page-width">
    {%- comment -%} Left column: stacked product images {%- endcomment -%}
    <div class="full-spectrum__images">
      {%- if section.settings.image_left_top != blank -%}
        <div class="full-spectrum__image-wrap">
          {{
            section.settings.image_left_top
            | image_url: width: 800
            | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 400px, 100vw', widths: '300, 400, 600, 800'
          }}
        </div>
      {%- endif -%}

      {%- if section.settings.image_left_bottom != blank -%}
        <div class="full-spectrum__image-wrap">
          {{
            section.settings.image_left_bottom
            | image_url: width: 800
            | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 400px, 100vw', widths: '300, 400, 600, 800'
          }}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Right column: content panel {%- endcomment -%}
    <div class="full-spectrum__content" data-fs-content>
      {%- if section.settings.heading != blank -%}
        <h2 class="full-spectrum__heading">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      <div class="full-spectrum__compounds">
        <div class="full-spectrum__compounds-list">
          {%- for block in section.blocks -%}
            <div class="full-spectrum__compound" data-fs-compound data-target-x="{{ block.settings.target_x }}" data-target-y="{{ block.settings.target_y }}" data-mobile-x="{{ block.settings.mobile_target_x }}" data-mobile-y="{{ block.settings.mobile_target_y }}" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                <div class="full-spectrum__compound-icon">
                  {{
                    block.settings.icon
                    | image_url: width: 240
                    | image_tag: loading: 'lazy', widths: '120, 160, 240'
                  }}
                </div>
              {%- endif -%}

              <div class="full-spectrum__compound-body">
                {%- if block.settings.name != blank -%}
                  <h3 class="full-spectrum__compound-name">{{ block.settings.name }}</h3>
                {%- endif -%}

                <div class="full-spectrum__line-row">
                  <span class="full-spectrum__line-start" data-fs-line-start></span>
                </div>

                {%- if block.settings.description != blank -%}
                  <p class="full-spectrum__compound-desc">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>

        {%- if section.settings.capsule_image != blank -%}
          <div class="full-spectrum__capsule" data-fs-capsule>
            {{
              section.settings.capsule_image
              | image_url: width: 500
              | image_tag: loading: 'lazy', widths: '220, 300, 440, 500'
            }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var section = document.querySelector('[data-fs-section]');
  if (!section) return;

  var LEADER_LINE_CDN = 'https://cdnjs.cloudflare.com/ajax/libs/leader-line/1.0.7/leader-line.min.js';
  var loaded = false;
  var lines = [];

  function loadScript(src, cb) {
    var s = document.createElement('script');
    s.src = src;
    s.onload = cb;
    document.body.appendChild(s);
  }

  var svg = null;
  var pathEls = [];
  var circleEls = [];

  function createSVG() {
    var capsule = section.querySelector('[data-fs-capsule]');
    if (!capsule) return;

    var compounds = section.querySelectorAll('[data-fs-compound]');
    var compoundsWrap = section.querySelector('.full-spectrum__compounds');
    compoundsWrap.style.position = 'relative';

    svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('class', 'full-spectrum__lines-svg');
    svg.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;overflow:visible;z-index:10;';
    compoundsWrap.appendChild(svg);

    compounds.forEach(function() {
      var path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('fill', 'none');
      path.setAttribute('stroke', '#2b2821');
      path.setAttribute('stroke-opacity', '0.4');
      svg.appendChild(path);
      pathEls.push(path);

      var circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('fill', 'none');
      circle.setAttribute('stroke', '#2b2821');
      circle.setAttribute('stroke-opacity', '0.4');
      svg.appendChild(circle);
      circleEls.push(circle);
    });
  }

  function updatePositions() {
    if (!svg) return;

    var capsule = section.querySelector('[data-fs-capsule]');
    if (!capsule) return;

    var isMobile = window.innerWidth < 1024;
    var capsuleImg = capsule.querySelector('img');
    var capsuleRect = capsuleImg ? capsuleImg.getBoundingClientRect() : capsule.getBoundingClientRect();
    var compounds = section.querySelectorAll('[data-fs-compound]');
    var compoundsWrap = section.querySelector('.full-spectrum__compounds');
    var panelRect = compoundsWrap.getBoundingClientRect();

    var strokeW = isMobile ? '1' : '1.5';
    var dashArr = isMobile ? '6 5' : '8 6';

    compounds.forEach(function(compound, i) {
      if (!pathEls[i] || !circleEls[i]) return;

      var lineRow = compound.querySelector('.full-spectrum__line-row');
      if (!lineRow) return;

      var rowRect = lineRow.getBoundingClientRect();

      var rawX, rawY;
      if (isMobile) {
        rawX = compound.getAttribute('data-mobile-x');
        rawY = compound.getAttribute('data-mobile-y');
      } else {
        rawX = compound.getAttribute('data-target-x');
        rawY = compound.getAttribute('data-target-y');
      }
      var targetX = rawX !== null && rawX !== '' ? parseFloat(rawX) : 50;
      var targetY = rawY !== null && rawY !== '' ? parseFloat(rawY) : 50;
      targetX = Math.max(5, Math.min(95, targetX));
      targetY = Math.max(5, Math.min(95, targetY));

      var sx = rowRect.left - panelRect.left;
      var sy = rowRect.top + (rowRect.height / 2) - panelRect.top;
      var dotX = capsuleRect.left - panelRect.left + capsuleRect.width * (targetX / 100);
      var dotY = capsuleRect.top - panelRect.top + capsuleRect.height * (targetY / 100);

      var d;
      if (Math.abs(dotY - sy) < 3) {
        d = 'M ' + sx + ' ' + sy + ' L ' + dotX + ' ' + dotY;
      } else {
        d = 'M ' + sx + ' ' + sy +
            ' L ' + dotX + ' ' + sy +
            ' L ' + dotX + ' ' + dotY;
      }

      pathEls[i].setAttribute('d', d);
      pathEls[i].setAttribute('stroke-width', strokeW);
      pathEls[i].setAttribute('stroke-dasharray', dashArr);

      circleEls[i].setAttribute('cx', dotX);
      circleEls[i].setAttribute('cy', dotY);
      circleEls[i].setAttribute('r', isMobile ? '4.5' : '5.5');
      circleEls[i].setAttribute('stroke-width', strokeW);
    });
  }

  function init() {
    createSVG();
    updatePositions();

    /* Update positions on resize — no remove/recreate, just update attributes */
    var ticking = false;
    window.addEventListener('resize', function() {
      if (!ticking) {
        requestAnimationFrame(function() {
          updatePositions();
          ticking = false;
        });
        ticking = true;
      }
    });
  }

  /* Lazy load LeaderLine when section is near viewport */
  var observer = new IntersectionObserver(function(entries) {
    if (entries[0].isIntersecting && !loaded) {
      loaded = true;
      observer.disconnect();

      if (typeof LeaderLine !== 'undefined') {
        init();
      } else {
        loadScript(LEADER_LINE_CDN, function() {
          /* Wait for images to load so capsule has correct dimensions */
          var capsuleImg = section.querySelector('[data-fs-capsule] img');
          if (capsuleImg && !capsuleImg.complete) {
            capsuleImg.addEventListener('load', init);
          } else {
            init();
          }
        });
      }
    }
  }, { rootMargin: '400px' });

  observer.observe(section);

  /* Shopify editor support */
  if (typeof Shopify !== 'undefined' && Shopify.designMode) {
    document.addEventListener('shopify:section:load', function(e) {
      if (e.target.querySelector('[data-fs-section]')) {
        setTimeout(drawLines, 500);
      }
    });
  }
})();
</script>

{% schema %}
{
  "name": "Full-Spectrum Extracts",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Move beyond curcumin to the power of full-spectrum oil extracts"
    },
    {
      "type": "header",
      "content": "Left images"
    },
    {
      "type": "image_picker",
      "id": "image_left_top",
      "label": "Top image"
    },
    {
      "type": "image_picker",
      "id": "image_left_bottom",
      "label": "Bottom image"
    },
    {
      "type": "header",
      "content": "Capsule image"
    },
    {
      "type": "image_picker",
      "id": "capsule_image",
      "label": "Capsule image (overlaps right edge)"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "compound",
      "name": "Compound",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Chemical structure icon"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Compound name",
          "default": "ar-Turmerone"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Stimulates production of endogenous antioxidant enzymes, the body's primary innate mechanism for inflammation reduction."
        },
        {
          "type": "header",
          "content": "Desktop dot position"
        },
        {
          "type": "range",
          "id": "target_x",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Desktop X (left to right %)",
          "default": 50
        },
        {
          "type": "range",
          "id": "target_y",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Desktop Y (top to bottom %)",
          "default": 50
        },
        {
          "type": "header",
          "content": "Mobile dot position"
        },
        {
          "type": "range",
          "id": "mobile_target_x",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Mobile X (left to right %)",
          "default": 50
        },
        {
          "type": "range",
          "id": "mobile_target_y",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Mobile Y (top to bottom %)",
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Full-Spectrum Extracts",
      "blocks": [
        {
          "type": "compound",
          "settings": {
            "name": "ar-Turmerone",
            "description": "Stimulates production of endogenous antioxidant enzymes, the body's primary innate mechanism for inflammation reduction.",
            "target_x": 85,
            "target_y": 18,
            "mobile_target_x": 80,
            "mobile_target_y": 15
          }
        },
        {
          "type": "compound",
          "settings": {
            "name": "Phenolics",
            "description": "Compounds like Calebin A and Bisacurone protect cartilage and reduce swelling in the joints.",
            "target_x": 90,
            "target_y": 40,
            "mobile_target_x": 85,
            "mobile_target_y": 35
          }
        },
        {
          "type": "compound",
          "settings": {
            "name": "Curcumin",
            "description": "The best-studied compound for temporary restoration of inflammatory balance.",
            "target_x": 85,
            "target_y": 60,
            "mobile_target_x": 80,
            "mobile_target_y": 60
          }
        },
        {
          "type": "compound",
          "settings": {
            "name": "Acid-Resistant Capsule",
            "description": "Proprietary capsule improves bioavailability by ensuring extracts reach the small intestine, where absorption is greatest.",
            "target_x": 90,
            "target_y": 80,
            "mobile_target_x": 85,
            "mobile_target_y": 80
          }
        }
      ]
    }
  ]
}
{% endschema %}
