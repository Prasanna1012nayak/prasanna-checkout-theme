{{ 'section-product-carousel.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="product-carousel section-{{ section.id }}-padding" data-pc-section>
  <div class="page-width">
    <div class="product-carousel__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="product-carousel__title">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <div class="product-carousel__nav">
        <button class="product-carousel__nav-btn" data-pc-prev aria-label="Previous">
          <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="product-carousel__nav-btn" data-pc-next aria-label="Next">
          <svg viewBox="0 0 24 24"><path d="M9 6l6 6-6 6"/></svg>
        </button>
      </div>
    </div>
  </div>

  <div class="page-width">
    <div class="product-carousel__track-wrap" data-pc-track-wrap>
      <div class="product-carousel__track" data-pc-track>
        {%- for block in section.blocks -%}
          {%- assign product = block.settings.product -%}
          {%- if product != blank -%}
            <a href="{{ product.url }}" class="product-carousel__card" data-pc-card {{ block.shopify_attributes }}>
              <div class="product-carousel__media" data-pc-media>
                {%- if product.featured_image != blank -%}
                  {{
                    product.featured_image
                    | image_url: width: 600
                    | image_tag:
                      loading: 'lazy',
                      sizes: '(min-width: 750px) 300px, 260px',
                      widths: '260, 300, 520, 600',
                      alt: product.title
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}

                {%- if block.settings.hover_video != blank -%}
                  <div class="product-carousel__video" data-pc-video>
                    <video
                      playsinline
                      loop
                      muted
                      preload="none"
                    >
                      {%- for source in block.settings.hover_video.sources -%}
                        <source src="{{ source.url }}" type="{{ source.mime_type }}">
                      {%- endfor -%}
                    </video>
                  </div>
                {%- endif -%}
              </div>

              <div class="product-carousel__info">
                <h3 class="product-carousel__product-title">{{ product.title }}</h3>
                <p class="product-carousel__product-price">
                  {{ product.price | money }}
                  {%- if product.compare_at_price > product.price -%}
                    <span class="compare-price">{{ product.compare_at_price | money }}</span>
                  {%- endif -%}
                </p>
              </div>
            </a>
          {%- else -%}
            <div class="product-carousel__card" {{ block.shopify_attributes }}>
              <div class="product-carousel__media">
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              <div class="product-carousel__info">
                <h3 class="product-carousel__product-title">Select a product</h3>
                <p class="product-carousel__product-price">$0.00</p>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var section = document.querySelector('[data-pc-section]');
  if (!section) return;

  var trackWrap = section.querySelector('[data-pc-track-wrap]');
  var prevBtn = section.querySelector('[data-pc-prev]');
  var nextBtn = section.querySelector('[data-pc-next]');
  var cards = section.querySelectorAll('[data-pc-card]');

  /* Nav buttons — scroll by one card width */
  function getScrollAmount() {
    var card = section.querySelector('.product-carousel__card');
    if (!card) return 300;
    var style = window.getComputedStyle(trackWrap);
    var gap = parseInt(style.gap) || 20;
    return card.offsetWidth + gap;
  }

  if (prevBtn) {
    prevBtn.addEventListener('click', function() {
      trackWrap.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', function() {
      trackWrap.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });
  }

  /* Hover video — play on mouseenter, pause on mouseleave */
  var mediaEls = section.querySelectorAll('[data-pc-media]');
  mediaEls.forEach(function(media) {
    var videoWrap = media.querySelector('[data-pc-video]');
    if (!videoWrap) return;
    var video = videoWrap.querySelector('video');
    if (!video) return;

    media.addEventListener('mouseenter', function() {
      video.play().catch(function() {});
    });

    media.addEventListener('mouseleave', function() {
      video.pause();
      video.currentTime = 0;
    });

    /* Touch: play on first tap, pause on second */
    var playing = false;
    media.addEventListener('touchstart', function(e) {
      if (!playing) {
        e.preventDefault();
        video.play().catch(function() {});
        playing = true;
      } else {
        video.pause();
        video.currentTime = 0;
        playing = false;
      }
    }, { passive: false });
  });
})();
</script>

{% schema %}
{
  "name": "Product Carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "video",
          "id": "hover_video",
          "label": "Hover video (plays on hover)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Carousel",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
