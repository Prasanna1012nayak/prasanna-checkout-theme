{{ 'section-360-model.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- assign dark = false -%}
{%- if section.settings.color_scheme == 'dark' -%}
  {%- assign dark = true -%}
{%- endif -%}

<div class="model-360{% if dark %} model-360--dark{% endif %} section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="model-360__inner">

      {%- comment -%} Text column {%- endcomment -%}
      <div class="model-360__text" data-m360-text>
        {%- if section.settings.badge != blank -%}
          <div class="model-360__badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
            {{ section.settings.badge }}
          </div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="model-360__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="model-360__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}

        {%- if section.settings.show_ar_button -%}
          <button class="model-360__ar-btn" data-m360-ar>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
              <path d="M12 2L2 7v10l10 5 10-5V7L12 2z"/>
              <path d="M12 22V12"/>
              <path d="M22 7l-10 5"/>
              <path d="M2 7l10 5"/>
            </svg>
            View in your space
          </button>
        {%- endif -%}
      </div>

      {%- comment -%} 3D Viewer column {%- endcomment -%}
      <div class="model-360__viewer" data-m360-viewer>
        <div class="model-360__glow"></div>

        {%- if section.settings.model_url != blank -%}
          <model-viewer
            class="model-360__model-viewer"
            src="{{ section.settings.model_url }}"
            {%- if section.settings.poster_image != blank -%}
              poster="{{ section.settings.poster_image | image_url: width: 1000 }}"
            {%- endif -%}
            {%- if section.settings.ios_model_url != blank -%}
              ios-src="{{ section.settings.ios_model_url }}"
            {%- endif -%}
            alt="{{ section.settings.heading | default: 'Product 3D model' }}"
            shadow-intensity="{{ section.settings.shadow_intensity }}"
            exposure="{{ section.settings.exposure }}"
            camera-controls
            touch-action="pan-y"
            {%- if section.settings.auto_rotate -%}
              auto-rotate
              auto-rotate-delay="{{ section.settings.auto_rotate_delay }}"
              rotation-per-second="{{ section.settings.rotation_speed }}deg"
            {%- endif -%}
            {%- if section.settings.show_ar_button -%}
              ar
              ar-modes="webxr scene-viewer quick-look"
            {%- endif -%}
            {%- if section.settings.environment_image != blank -%}
              environment-image="{{ section.settings.environment_image }}"
            {%- endif -%}
            loading="lazy"
            reveal="auto"
            interpolation-decay="100"
          >
            {%- comment -%} Loading progress bar {%- endcomment -%}
            <div class="model-360__progress-wrapper" slot="progress-bar">
              <div class="model-360__progress-track">
                <div class="model-360__progress-bar"></div>
              </div>
            </div>

            {%- comment -%} AR button inside model-viewer {%- endcomment -%}
            {%- if section.settings.show_ar_button -%}
              <button slot="ar-button" class="model-360__ar-inner-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                  <path d="M12 2L2 7v10l10 5 10-5V7L12 2z"/>
                </svg>
                AR
              </button>
            {%- endif -%}
          </model-viewer>

        {%- else -%}
          <div class="model-360__placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48">
              <path d="M12 2L2 7v10l10 5 10-5V7L12 2z"/>
              <path d="M12 22V12"/>
              <path d="M22 7l-10 5"/>
              <path d="M2 7l10 5"/>
            </svg>
            <p>Add a 3D model URL (.glb file) in the section settings</p>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

<script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js"></script>

<script>
(function() {
  /* Progress bar animation */
  var mv = document.querySelector('.model-360__model-viewer');
  if (mv) {
    mv.addEventListener('progress', function(e) {
      var bar = mv.querySelector('.model-360__progress-bar');
      if (bar) bar.style.width = (e.detail.totalProgress * 100) + '%';
    });
    mv.addEventListener('load', function() {
      var wrapper = mv.querySelector('.model-360__progress-wrapper');
      if (wrapper) wrapper.classList.add('is-hidden');
    });

    /* AR button trigger from outside */
    var arBtn = document.querySelector('[data-m360-ar]');
    if (arBtn) {
      arBtn.addEventListener('click', function() {
        mv.activateAR();
      });
    }
  }

  /* Scroll entrance animation */
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, { threshold: 0.15 });

    var textEl = document.querySelector('[data-m360-text]');
    var viewerEl = document.querySelector('[data-m360-viewer]');
    if (textEl) obs.observe(textEl);
    if (viewerEl) obs.observe(viewerEl);
  }
})();
</script>

{% schema %}
{
  "name": "360° Model Viewer",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge text",
      "default": "360° VIEW"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See Every Angle"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Interact with the 3D model — drag to rotate, pinch to zoom, and view from every angle."
    },
    {
      "type": "header",
      "content": "3D Model"
    },
    {
      "type": "url",
      "id": "model_url",
      "label": "3D Model URL (.glb)",
      "info": "Upload a .glb file to Shopify Files and paste the URL here"
    },
    {
      "type": "url",
      "id": "ios_model_url",
      "label": "iOS AR model URL (.usdz)",
      "info": "Optional: for AR on iPhone/iPad"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster image",
      "info": "Shown while the 3D model loads"
    },
    {
      "type": "header",
      "content": "Rotation"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate",
      "default": true
    },
    {
      "type": "range",
      "id": "rotation_speed",
      "min": 10,
      "max": 120,
      "step": 5,
      "unit": "°/s",
      "label": "Rotation speed",
      "default": 30,
      "info": "Degrees per second"
    },
    {
      "type": "range",
      "id": "auto_rotate_delay",
      "min": 0,
      "max": 5000,
      "step": 500,
      "unit": "ms",
      "label": "Auto-rotate delay",
      "default": 1000,
      "info": "Delay before auto-rotation starts after interaction"
    },
    {
      "type": "header",
      "content": "Lighting"
    },
    {
      "type": "range",
      "id": "shadow_intensity",
      "min": 0,
      "max": 2,
      "step": 0.1,
      "label": "Shadow intensity",
      "default": 1
    },
    {
      "type": "range",
      "id": "exposure",
      "min": 0.1,
      "max": 3,
      "step": 0.1,
      "label": "Exposure / brightness",
      "default": 1
    },
    {
      "type": "url",
      "id": "environment_image",
      "label": "Environment image (.hdr)",
      "info": "Optional: custom lighting environment"
    },
    {
      "type": "header",
      "content": "AR"
    },
    {
      "type": "checkbox",
      "id": "show_ar_button",
      "label": "Show AR button",
      "default": true,
      "info": "Lets users view the product in their space (on supported devices)"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "dark", "label": "Dark" }
      ],
      "default": "light"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "360° Model Viewer"
    }
  ]
}
{% endschema %}
